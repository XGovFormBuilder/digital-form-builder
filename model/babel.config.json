{
  "env": {
    "node": {
      "presets": [
        "@babel/typescript",
        [
          "@babel/preset-env",
          {
            "targets": {
              "node": "22"
            }
          }
        ]
      ],
      "plugins": [
        "@babel/plugin-transform-runtime"
      ],
      "sourceMaps": true
    },
    "browser": {
      "presets": [
        "@babel/typescript",
        "@babel/preset-env"
      ],
      "plugins": [
        "@babel/plugin-transform-runtime"
      ],
      "sourceMaps": true
    }
  }
}
