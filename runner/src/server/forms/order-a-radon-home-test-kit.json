{
  "metadata": {},
  "startPage": "/test-kit-start",
  "name": "Order a radon gas test kit",
  "serviceName": "Order a radon risk report",
  "confirmationSessionTimeout": 2000,
  "pages": [
    {
      "path": "/test-kit-start",
      "title": "Order a radon home test kit",
      "backLinkFallback": "https://www.ukhsa-protectionservices.org.uk/",
      "components": [
        {
          "name": "qwplwo",
          "options": {},
          "type": "Para",
          "content": "Use this service to order a radon gas test kit for your home.\n</br></br>\nThis service costs £52.80 including VAT.\n</br></br>\nOrdering a kit takes around 5 minutes. It may take up to 10 working days after you order for the kit to be sent.\n</br></br>\nThe kit contains two detectors. one for the living area and one for the bedroom of a residential property.\n</br></br>\nIt doesn't matter how big the home is or how many rooms there are. The detectors just need to be placed in any regularly used living area and bedroom.\n</br></br>\nOnce your kit arrives, we'll send you instructions on how to carry out the test.\n</br></br>\nYou'll get the results and advice on what to do next within 20 working days after you return the kit.\n</br></br>\n<b>Important information before you continue</b>\n</br></br>\nThe test will not be valid if:</br>",
          "schema": {}
        },
        {
          "name": "VDzNQL",
          "options": {},
          "type": "List",
          "hint": "",
          "list": "wnGWzk",
          "title": "The test will not be valid if",
          "values": { "type": "listRef" },
          "schema": {}
        },
        {
          "name": "gkopdo",
          "options": {},
          "type": "Para",
          "content": "\nThis is because the way people live in a home can affect the radon level. For example. how often they open windows and doors, or how they heat the house.\n</br></br>\n<b>Before you start</b>\n</br></br>\nYou'll need your:</br>",
          "schema": {}
        },
        {
          "name": "xOxwdQ",
          "options": {},
          "type": "List",
          "hint": "",
          "title": "You'll need your:",
          "list": "DjwCMK",
          "schema": {}
        }
      ],
      "next": [
        { "path": "/measurement-address-postcode" }
      ],
      "controller": "./pages/start.js"
    },
    {
      "path": "/measurement-address-postcode",
      "title": "Enter the address you want to measure the radon level",
      "components": [
        {
          "name": "postcodeLookup",
          "options": {
            "customValidationMessages": {
              "string.empty": "Enter postcode",
              "string.pattern.base": "Enter a full UK postcode",
              "string.max": "Postcode must be less than 10 characters"
            },
            "autocomplete": "postal-code",
            "exposeToContext": true,
            "format": {
              "trim": true,
              "case": "upper"
            }
          },
          "schema": { 
            "max": 10,
            "regex": "^[\\s]*[A-z]{1,2}[0-9][A-z0-9]?[\\s]*[0-9]{1,2}[ABD-hJLNP-uW-z]{2}[\\s]*$"
          },
          "type": "TextField",
          "title": "Postcode",
          "hint": "For example, AA3 1AB"
        },
        {
          "name": "buildingLookup",
          "options": {
            "customValidationMessages": {
              "string.empty": "Enter building number or name",
              "string.max": "Building name must be less than 100 characters"
            },
            "exposeToContext": true
          },
          "schema": { "max": 100 },
          "type": "TextField",
          "title": "Building number or name",
          "hint": "For example, 15 or Prospect cottage"
        }
      ],
      "customButtonText": "Find address",
      "componentsAfter": [
        {
          "name": "Ayhiny2",
          "options": {},
          "type": "Html",
          "content": "<br><a href=\"enter-report-address\">Enter address manually</a>"
        }
      ],
      "controller": "FindAnAddressPageController",
      "next": [
        {
          "path": "/correct-report-address",
          "condition": "hasMatchedAddressCondition"
        },
        { "path": "/select-report-address" },
        {
          "path": "/no-addresses-found",
          "condition": "noAddressesCondition"
        }
      ]
    },
    {
      "path": "/correct-report-address",
      "title": "Is this the correct address?",
      "components": [
        {
          "name": "matchedAddressDisplay",
          "options": {},
          "type": "DisplayAddress",
          "content": "{{ matchedAddress.address }}"
        },
        {
          "name": "isCorrectAddress",
          "options": {
            "hideTitle": true,
            "customValidationMessages": {
              "any.required": "Select Yes if this is the correct address"
            }
          },
          "type": "YesNoField",
          "title": "Is this the correct address?"
        }
      ],
      "componentsAfter": [
        {
          "name": "Ayhiny2",
          "options": {},
          "type": "Html",
          "content": "<br><a href=\"enter-report-address\">Enter address manually</a>"
        }
      ],
      "next": [
        {
          "path": "/have-you-tested-this-address-before-using-a-gas-test-kit-purchased-from-us",
          "condition": "isCorrectAddressYes"
        },
        { "path": "/order-risk-report-find-an-address" }
      ]
    },
    {
      "path": "/select-report-address",
      "title": "Select an address",
      "components": [
        {
          "name": "addressesFoundHeading",
          "options": {},
          "type": "Html",
          "content": "<p class=\"govuk-body-m\">{{ numberOfAddresses }} addresses found for <b>{{ postcodeLookup }}</b> and <b>{{ buildingLookup }}</b>. <a href=\"measurement-address-postcode\">Search again</a></p>"
        },
        {
          "name": "selectedAddress",
          "options": {
            "hideTitle": true,
            "customValidationMessages": {
              "any.required": "Select an address"
            }
          },
          "type": "RadiosField",
          "title": "Select an address",
          "list": "addressesList"
        }
      ],
      "componentsAfter": [
        {
          "name": "Ayhiny2",
          "options": {},
          "type": "Html",
          "content": "<br><a href=\"enter-report-address\">Enter address manually</a>"
        }
      ],
      "next": [{ "path": "/have-you-tested-this-address-before-using-a-gas-test-kit-purchased-from-us" }]
    },
    {
      "path": "/no-addresses-found",
      "title": "No addresses found for {{ postcodeLookup }} and {{ buildingLookup }}",
      "components": [
        {
          "name": "noAddressesFoundMessage",
          "options": {},
          "type": "Para",
          "content": "Check your address for mistakes, then try again.<br><br>Check you have entered the address correctly, then try again."
        },
        {
          "name": "searchAgain",
          "options": {},
          "type": "Html",
          "content": "<p class=\"govuk-body-m\"><a href=\"order-risk-report-find-an-address\">Change your search</a> or <a href=\"enter-report-address\">enter address manually</a></p>"
        }
      ],
      "next": [
        { "path": "/order-risk-report-find-an-address" }
      ]
    },
    {
      "path": "/enter-report-address",
      "title": "Enter the address you want to measure the radon level",
      "components": [
        {
          "name": "addressLine1Lookup",
          "options": {
            "customValidationMessages": {
