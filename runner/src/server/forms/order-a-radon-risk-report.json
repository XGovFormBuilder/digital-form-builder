              "string.pattern.base": "Enter a full UK postcode",
              "string.max": "Postcode must be less than 10 characters"
            },
            "autocomplete": "postal-code",
            "exposeToContext": true,
            "format": {
              "trim": true,
              "case": "upper"
            }
          },
          "schema": {
            "max": 10,
            "regex": "^[\\s]*[A-z]{1,2}[0-9][A-z0-9]?[\\s]*[0-9]{1,2}[ABD-hJLNP-uW-z]{2}[\\s]*$"
          },
          "type": "TextField",
          "title": "Postcode",
          "hint": "For example, AA3 1AB"
        },
        {
          "name": "buildingLookup",
          "options": {
            "customValidationMessages": {
              "string.empty": "Enter building number or name",
              "string.max": "Building name must be less than 100 characters"
            },
